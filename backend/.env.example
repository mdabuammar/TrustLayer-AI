# TrustLayer AI Backend Configuration

# Directory where uploaded files will be stored (relative to backend folder or absolute path)
UPLOAD_DIR=data/uploads

# Port and Host for backend server (optional)
PORT=8000
HOST=127.0.0.1

# OpenRouter Configuration for LLM Answer Generation
OPENROUTER_API_KEY=your_api_key_here
OPENROUTER_MODEL=openrouter/free

